{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDTree",
  "version": "0.3.0",
  "identifier": "com.kuimoani.mdtree",
  "build": {
    "beforeDevCommand": "pnpm run dev:vite",
    "beforeBuildCommand": "pnpm run build:vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../out/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "MDTree",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
